rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definition
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/profiles/$(request.auth.uid)) && get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.role == 'admin'; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // Validation Blueprints
    function isValidProfile(data) {
      return data.keys().hasAll(['id', 'email']) 
        && data.id == request.auth.uid
        && data.email is string && data.email.size() <= 256
        && (!('display_name' in data) || (data.display_name is string && data.display_name.size() <= 128))
        && (!('role' in data) || (data.role in ['user', 'admin']))
        && (!('bio' in data) || (data.bio is string && data.bio.size() <= 500))
        && (!('location' in data) || (data.location is string && data.location.size() <= 128))
        && (!('created_at' in data) || (data.created_at is timestamp));
    }

    function isValidChat(data) {
      return data.keys().hasAll(['user_id']) 
        && data.user_id == request.auth.uid
        && (!('title' in data) || (data.title is string && data.title.size() <= 256))
        && (!('message_count' in data) || (data.message_count is int))
        && (!('is_archived' in data) || (data.is_archived is bool))
        && (!('last_message' in data) || (data.last_message is string && data.last_message.size() <= 1000));
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['chat_id', 'user_id', 'role', 'content'])
        && data.user_id == request.auth.uid
        && data.role in ['user', 'assistant']
        && data.content is string && data.content.size() <= 10000
        && (!('image_urls' in data) || (data.image_urls is list && data.image_urls.size() <= 10));
    }

    function isValidAdminConfig(data) {
      return (!('system_prompt' in data) || (data.system_prompt is string && data.system_prompt.size() <= 5000))
        && (!('model' in data) || (data.model is string && data.model.size() <= 128))
        && (!('image_model' in data) || (data.image_model is string && data.image_model.size() <= 128))
        && (!('temperature' in data) || (data.temperature is float || data.temperature is int))
        && (!('max_tokens' in data) || (data.max_tokens is int));
    }

    // 1. Profiles
    match /profiles/{userId} {
      allow get: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow list: if isAdmin();
      allow create: if isSignedIn() && isOwner(userId) && isValidProfile(incoming()) && incoming().role == 'user'; // Users can't self-promote to admin
      allow update: if isSignedIn() && (
        (isOwner(userId) && isValidProfile(incoming()) && incoming().role == existing().role && incoming().id == existing().id) ||
        isAdmin()
      );
    }

    // 2. Chats
    match /chats/{chatId} {
      allow get: if isSignedIn() && (isOwner(existing().user_id) || isAdmin());
      allow list: if isSignedIn() && resource.data.user_id == request.auth.uid;
      allow create: if isSignedIn() && isValidChat(incoming());
      allow update: if isSignedIn() && (
        (isOwner(existing().user_id) && isValidChat(incoming()) && incoming().user_id == existing().user_id) ||
        isAdmin()
      );
      allow delete: if isSignedIn() && (isOwner(existing().user_id) || isAdmin());
      
      // 3. Messages Subcollection
      match /messages/{messageId} {
        allow get, list: if isSignedIn() && get(/databases/$(database)/documents/chats/$(chatId)).data.user_id == request.auth.uid;
        allow create: if isSignedIn() && get(/databases/$(database)/documents/chats/$(chatId)).data.user_id == request.auth.uid && isValidMessage(incoming());
        allow update, delete: if isSignedIn() && (get(/databases/$(database)/documents/chats/$(chatId)).data.user_id == request.auth.uid || isAdmin());
      }
    }

    // 4. Admin Config
    match /admin_config/{configId} {
      allow get: if true; // Everyone can see global settings for AI models
      allow list: if isAdmin();
      allow write: if isAdmin() && isValidAdminConfig(incoming());
    }
  }
}
