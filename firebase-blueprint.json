{
  "entities": {
    "Profile": {
      "title": "User Profile",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Firebase UID" },
        "email": { "type": "string", "format": "email" },
        "display_name": { "type": "string" },
        "photo_url": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "image_count": { "type": "integer" },
        "max_images": { "type": "integer" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email"]
    },
    "AppConfig": {
      "title": "Application Configuration",
      "description": "Global settings for the application including prompts",
      "type": "object",
      "properties": {
        "main_prompt": { "type": "string" },
        "technical_instructions": { "type": "array", "items": { "type": "string" } },
        "updated_at": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/profiles/{userId}": {
      "schema": "Profile",
      "description": "User profiles"
    },
    "/config/settings": {
      "schema": "AppConfig",
      "description": "System configuration with prompts"
    }
  }
}
