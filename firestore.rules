rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definition
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() && (
        (exists(/databases/$(database)/documents/profiles/$(request.auth.uid)) && get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.role == 'admin')
        || (request.auth.token.email == 'celoolarnosol@gmail.com' && request.auth.token.email_verified == true)
      ); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // Validation Blueprints
    function isValidProfile(data) {
      return data.keys().hasAll(['id', 'email']) 
        && data.id == request.auth.uid
        && data.email is string && data.email.size() <= 256
        && (!('display_name' in data) || (data.display_name is string && data.display_name.size() <= 128))
        && (!('role' in data) || (data.role in ['user', 'admin']))
        && (!('photo_url' in data) || (data.photo_url is string))
        && (!('image_count' in data) || (data.image_count is int))
        && (!('max_images' in data) || (data.max_images is int))
        && (!('max_chats' in data) || (data.max_chats is int))
        && (!('is_active' in data) || (data.is_active is bool))
        && (!('created_at' in data) || (data.created_at is timestamp));
    }

    function isValidChat(data) {
      return data.keys().hasAll(['user_id']) 
        && data.user_id == request.auth.uid
        && (!('title' in data) || (data.title is string && data.title.size() <= 256))
        && (!('message_count' in data) || (data.message_count is int))
        && (!('is_archived' in data) || (data.is_archived is bool))
        && (!('last_message' in data) || (data.last_message is string && data.last_message.size() <= 1000))
        && (!('updated_at' in data) || (data.updated_at is timestamp));
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['chat_id', 'user_id', 'role', 'content'])
        && data.user_id == request.auth.uid
        && data.role in ['user', 'assistant']
        && data.content is string && data.content.size() <= 20000
        && (!('image_urls' in data) || (data.image_urls is list && data.image_urls.size() <= 10))
        && (!('generated_image_urls' in data) || (data.generated_image_urls is list))
        && (!('created_at' in data) || (data.created_at is timestamp));
    }

    function isValidAppConfig(data) {
      return (!('main_prompt' in data) || (data.main_prompt is string && data.main_prompt.size() <= 20000))
        && (!('technical_instructions' in data) || (data.technical_instructions is list && data.technical_instructions.size() <= 50))
        && (!('updated_at' in data) || (data.updated_at is timestamp));
    }

    // 1. Profiles
    match /profiles/{userId} {
      allow get: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow list: if isAdmin();
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow delete: if isAdmin();
    }

    // 2. Config
    match /config/settings {
      allow get: if isSignedIn();
      allow write: if isAdmin() && isValidAppConfig(incoming());
    }

    match /config/whitelist {
      allow get: if isSignedIn(); // Users need to check if they are whitelisted on login
      allow write: if isAdmin();
    }

    // Legacy Support (optional, can keep for structural safety)
    match /chats/{chatId} {
      allow read, write: if false; 
      match /messages/{messageId} {
        allow read, write: if false;
      }
    }
  }
}
